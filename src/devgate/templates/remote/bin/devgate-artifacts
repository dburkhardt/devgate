#!/usr/bin/env python3
from __future__ import annotations

import json
import os
from pathlib import Path


def main() -> int:
    config = _load_config()
    print(config["artifact_root"])
    print(config["artifact_base_url"])
    return 0


def _load_config() -> dict:
    path = Path(os.path.expanduser("~/.devgate/effective-config.json"))
    if not path.exists():
        raise SystemExit(f"missing effective config: {path}")
    return json.loads(path.read_text(encoding="utf-8"))


if __name__ == "__main__":
    raise SystemExit(main())
